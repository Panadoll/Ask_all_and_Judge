{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.0.0",
  "description": "__MSG_appDesc__",
  "default_locale": "en",
  "permissions": [
    "tabs",
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://chat.qwen.ai/*",
    "https://www.doubao.com/*",
    "https://doubao.com/*",
    "https://chat.deepseek.com/*",
    "https://grok.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "chrome_url_overrides": {},
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content-scripts/common.js", "content-scripts/ai/chatgpt-injector.js"],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content-scripts/common.js", "content-scripts/ai/claude-injector.js"],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content-scripts/common.js", "content-scripts/ai/gemini-injector.js"],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chat.qwen.ai/*"],
      "js": ["content-scripts/common.js", "content-scripts/ai/qwen-injector.js"],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.doubao.com/*", "https://doubao.com/*"],
      "js": ["content-scripts/common.js", "content-scripts/ai/doubao-injector.js"],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["content-scripts/common.js", "content-scripts/ai/deepseek-injector.js"],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": ["https://grok.com/*"],
      "js": ["content-scripts/common.js", "content-scripts/ai/grok-injector.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}